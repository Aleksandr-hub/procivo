<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Organization\Domain\Entity\Role" table="organization_roles">

        <id name="id" type="string" length="36" column="id"/>

        <field name="organizationId" type="string" length="36" column="organization_id"/>
        <field name="name" type="string" length="100" column="name"/>
        <field name="description" type="text" column="description" nullable="true"/>
        <field name="isSystem" type="boolean" column="is_system"/>
        <field name="hierarchy" type="integer" column="hierarchy"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="true"/>

        <indexes>
            <index name="idx_role_org_id" columns="organization_id"/>
        </indexes>

        <unique-constraints>
            <unique-constraint name="uniq_role_name_org" columns="name,organization_id"/>
        </unique-constraints>

    </entity>

</doctrine-mapping>
