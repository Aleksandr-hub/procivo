<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Organization\Domain\Entity\Position" table="organization_positions">

        <id name="id" type="string" length="36" column="id"/>

        <field name="organizationId" type="string" length="36" column="organization_id"/>
        <field name="departmentId" type="string" length="36" column="department_id"/>
        <field name="name" type="string" length="255" column="name"/>
        <field name="description" type="text" nullable="true" column="description"/>
        <field name="sortOrder" type="integer" column="sort_order"/>
        <field name="isHead" type="boolean" column="is_head"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="true"/>

        <indexes>
            <index name="idx_pos_org_id" columns="organization_id"/>
            <index name="idx_pos_dept_id" columns="department_id"/>
        </indexes>

    </entity>

</doctrine-mapping>
