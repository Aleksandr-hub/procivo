<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Identity\Domain\Entity\User" table="identity_users">

        <id name="id" type="string" length="36" column="id"/>

        <field name="email" type="string" length="255" unique="true" column="email"/>
        <field name="password" type="string" length="255" column="password"/>
        <field name="firstName" type="string" length="100" column="first_name"/>
        <field name="lastName" type="string" length="100" column="last_name"/>
        <field name="status" type="string" length="20" column="status"/>
        <field name="roles" type="json" column="roles"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="true"/>
        <field name="avatarPath" type="string" length="500" column="avatar_path" nullable="true"/>
        <field name="deletedAt" type="datetime_immutable" column="deleted_at" nullable="true"/>
        <field name="totpSecret" type="text" column="totp_secret" nullable="true"/>
        <field name="totpEnabled" type="boolean" column="totp_enabled">
            <options>
                <option name="default">false</option>
            </options>
        </field>
        <field name="backupCodes" type="json" column="backup_codes" nullable="true"/>

    </entity>

</doctrine-mapping>
