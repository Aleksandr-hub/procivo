# Procivo Backend — Environment Configuration Template
#
# Copy this file to .env and adjust values for your local setup:
#   cp backend/.env.example backend/.env
#
# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
# DO NOT commit real secrets to version control.

###> symfony/framework-bundle ###
# Application environment: dev, test, or prod
APP_ENV=dev
# Random 32-char secret — generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change-me-in-production
###< symfony/framework-bundle ###

###> symfony/routing ###
# Base URL used for generating absolute URLs in console commands / emails
DEFAULT_URI=http://localhost:8080
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# PostgreSQL DSN — uses Docker-internal hostname "postgres" by default
DATABASE_URL="postgresql://procivo:procivo@postgres:5432/procivo?serverVersion=18&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# RabbitMQ AMQP DSN — uses Docker-internal hostname "rabbitmq" by default
MESSENGER_TRANSPORT_DSN=amqp://procivo:procivo@rabbitmq:5672/%2f/messages
###< symfony/messenger ###

###> symfony/mailer ###
# Mailpit SMTP for local development (catches all outgoing mail)
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=noreply@procivo.local
###< symfony/mailer ###

###> procivo ###
# Frontend origin — used for CORS and email links
FRONTEND_URL=http://localhost:5173
###< procivo ###

###> redis ###
# Redis connection — uses Docker-internal hostname "redis" by default
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
###< redis ###

###> mercure ###
# Mercure hub URLs — internal for publishing, public for browser connections
MERCURE_URL=http://mercure:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
# Must match MERCURE_PUBLISHER_JWT_KEY and MERCURE_SUBSCRIBER_JWT_KEY in docker-compose.yml
MERCURE_JWT_SECRET=procivo-mercure-secret-key-change-in-production
###< mercure ###

###> localstack/s3 ###
# LocalStack S3 — test credentials work for local dev
AWS_ENDPOINT=http://localstack:4566
AWS_ENDPOINT_PUBLIC=http://localhost:4566
AWS_REGION=eu-central-1
AWS_BUCKET=procivo
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
###< localstack/s3 ###

###> lexik/jwt-authentication-bundle ###
# Generate JWT keys:
#   mkdir -p backend/config/jwt
#   openssl genpkey -algorithm RSA -out backend/config/jwt/private.pem -pkeyopt rsa_keygen_bits:4096
#   openssl rsa -pubout -in backend/config/jwt/private.pem -out backend/config/jwt/public.pem
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Leave empty if keys have no passphrase (default)
JWT_PASSPHRASE=
###< lexik/jwt-authentication-bundle ###
